<div class="material-picker position-relative" @ref="_root">
    <div class="form-control d-flex align-items-center gap-2 @(_open ? "border-primary" : "")"
         style="cursor:pointer" @onclick="Open" role="combobox" aria-expanded="@_open">
        @if (_selectedMaterial != null)
        {
            <span style="width:1em;height:1em;background:#@_selectedMaterial.ColorHex;border-radius:50%;border:1px solid var(--bs-border-color);flex-shrink:0"></span>
            <span class="text-truncate">@_selectedMaterial.Brand @_selectedMaterial.Type @(_selectedMaterial.ColorName != null ? $"- {_selectedMaterial.ColorName}" : "")</span>
        }
        else
        {
            <span class="text-muted">@L["spool.material.select"]</span>
        }
        <i class="bi bi-chevron-down ms-auto flex-shrink-0"></i>
    </div>

    @if (_open)
    {
        <div class="position-absolute w-100 bg-body border rounded-bottom shadow-lg" style="z-index:1050;max-height:350px;overflow:hidden;display:flex;flex-direction:column">
            <div class="p-2 border-bottom">
                <input class="form-control form-control-sm" placeholder="@L["material.search"]"
                       @ref="_searchInput" value="@_query" @oninput="OnQuery" autocomplete="off" />
            </div>
            <div style="overflow-y:auto;flex:1">
                @if (_searching)
                {
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                }
                else if (string.IsNullOrWhiteSpace(_query))
                {
                    @if (_favorites.Count > 0)
                    {
                        <div class="px-3 py-1 text-muted small fw-semibold">@L["material.favorites"]</div>
                        @foreach (var m in _favorites)
                        {
                            <div class="material-picker-item d-flex align-items-center gap-2 px-3 py-2 @(m.Id == Value ? "bg-primary-subtle" : "")"
                                 role="option" @onclick="() => Select(m)" @onclick:stopPropagation>
                                <span style="width:1.2em;height:1.2em;background:#@m.ColorHex;border-radius:50%;border:1px solid var(--bs-border-color);flex-shrink:0"></span>
                                <div class="d-flex flex-column min-w-0">
                                    <span class="text-truncate fw-semibold small">@m.Brand @m.Type</span>
                                    <span class="text-truncate text-muted" style="font-size:.75rem">
                                        @(m.ColorName ?? $"#{m.ColorHex}")
                                    </span>
                                </div>
                                <i class="bi bi-star-fill text-warning ms-auto"></i>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-3 small">@L["material.picker.hint"]</div>
                    }
                }
                else if (_results.Count == 0)
                {
                    <div class="text-center text-muted py-3 small">@L["common.none"]</div>
                }
                else
                {
                    @foreach (var m in _results)
                    {
                        <div class="material-picker-item d-flex align-items-center gap-2 px-3 py-2 @(m.Id == Value ? "bg-primary-subtle" : "")"
                             role="option" @onclick="() => Select(m)" @onclick:stopPropagation>
                            <span style="width:1.2em;height:1.2em;background:#@m.ColorHex;border-radius:50%;border:1px solid var(--bs-border-color);flex-shrink:0"></span>
                            <div class="d-flex flex-column min-w-0">
                                <span class="text-truncate fw-semibold small">@m.Brand @m.Type</span>
                                <span class="text-truncate text-muted" style="font-size:.75rem">
                                    @(m.ColorName ?? $"#{m.ColorHex}")
                                    @if (m.MinTempCelsius > 0 || m.MaxTempCelsius > 0)
                                    {
                                        <span class="ms-1">@m.MinTempCelsius–@m.MaxTempCelsius °C</span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

