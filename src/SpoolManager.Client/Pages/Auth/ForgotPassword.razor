@page "/forgot-password"
@inject AuthService Auth
@inject LocalizationService L
@inject NavigationManager Nav

<PageTitle>@L["auth.forgot.password"] – @L["app.name"]</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh;padding:1rem">
    <div style="width:100%;max-width:420px">
        <div class="text-center mb-4">
            <i class="bi bi-layers-half text-primary" style="font-size:2.5rem"></i>
            <div class="fw-bold fs-4 mt-1">@L["app.name"]</div>
        </div>
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="fs-5 fw-semibold mb-3">
                    <i class="bi bi-key me-2"></i>@L["auth.forgot.password"]
                </h1>

                @if (_sent)
                {
                    <div class="alert alert-success py-2">
                        <i class="bi bi-check-circle me-1"></i>@L["auth.forgot.success"]
                    </div>
                    <a href="/login" class="btn btn-primary w-100">@L["auth.login"]</a>
                }
                else
                {
                    <p class="text-muted small mb-3">@L["auth.forgot.hint"]</p>

                    @if (_error != null)
                    {
                        <div class="alert alert-danger py-2">@_error</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">@L["auth.email"]</label>
                        <input class="form-control" type="email" @bind="_email" required autocomplete="email" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="SendAsync" disabled="@_loading">
                        @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        @L["auth.forgot.submit"]
                    </button>
                }

                <hr />
                <div class="text-center">
                    <small><a href="/login">@L["auth.login"]</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _loading;
    private bool _sent;
    private string? _error;

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_email)) { _error = L["auth.email.required"]; return; }
        _loading = true;
        _error = null;
        var resp = await Auth.ForgotPasswordAsync(_email);
        _loading = false;
        _sent = resp.IsSuccessStatusCode;
        if (!_sent) _error = L["common.error"];
    }
}
