@page "/verify-email"

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh;padding:1rem">
    <div style="width:100%;max-width:420px">
        <div class="text-center mb-4">
            <i class="bi bi-envelope-check fs-1 text-primary"></i>
            <h2 class="mt-2">@L["auth.verify.title"]</h2>
        </div>

        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
        }
        else if (_success)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle me-2"></i>@L["auth.verify.success"]
            </div>
            <div class="text-center mt-3">
                <a href="/login" class="btn btn-primary">@L["auth.login"]</a>
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                <i class="bi bi-x-circle me-2"></i>@L["auth.verify.error"]
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    <p class="small text-muted mb-2">@L["auth.resend.hint"]</p>

                    @if (_resendSuccess)
                    {
                        <div class="alert alert-success py-2 small">
                            <i class="bi bi-check-circle me-1"></i>@L["auth.resend.success"]
                        </div>
                    }

                    <div class="mb-2">
                        <input class="form-control form-control-sm" type="email" @bind="_resendEmail"
                               placeholder="@L["auth.email"]" />
                    </div>
                    <button class="btn btn-sm btn-outline-primary w-100" @onclick="ResendAsync" disabled="@_resending">
                        @if (_resending) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @L["auth.resend.button"]
                    </button>
                </div>
            </div>

            <div class="text-center mt-3">
                <a href="/login" class="btn btn-outline-secondary">@L["auth.login"]</a>
            </div>
        }
    </div>
</div>

