@page "/reset-password"

<PageTitle>@L["auth.reset.password"] – @L["app.name"]</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh;padding:1rem">
    <div style="width:100%;max-width:420px">
        <div class="text-center mb-4">
            <i class="bi bi-layers-half text-primary" style="font-size:2.5rem"></i>
            <div class="fw-bold fs-4 mt-1">@L["app.name"]</div>
        </div>
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="fs-5 fw-semibold mb-3">
                    <i class="bi bi-key me-2"></i>@L["auth.reset.password"]
                </h1>

                @if (_success)
                {
                    <div class="alert alert-success py-2">
                        <i class="bi bi-check-circle me-1"></i>@L["auth.reset.success"]
                    </div>
                    <a href="/login" class="btn btn-primary w-100">@L["auth.login"]</a>
                }
                else if (string.IsNullOrEmpty(_token))
                {
                    <div class="alert alert-danger py-2">@L["auth.reset.invalid"]</div>
                    <a href="/forgot-password" class="btn btn-outline-primary w-100">@L["auth.forgot.password"]</a>
                }
                else
                {
                    @if (_error != null)
                    {
                        <div class="alert alert-danger py-2">@_error</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">@L["auth.new.password"]</label>
                        <input class="form-control" type="password" @bind="_password" minlength="8" required autocomplete="new-password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["auth.confirm.password"]</label>
                        <input class="form-control" type="password" @bind="_confirmPassword" minlength="8" required autocomplete="new-password" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="ResetAsync" disabled="@_loading">
                        @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        @L["auth.reset.submit"]
                    </button>
                }
            </div>
        </div>
    </div>
</div>

