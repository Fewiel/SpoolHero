@page "/changelog"
@using Markdig

<PageTitle>@L["nav.changelog"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-journal-text me-2"></i>@L["nav.changelog"]</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border"></div></div>
}
else
{
    @foreach (var entry in _entries)
    {
        <div class="card mb-3">
            <div class="card-body changelog-content">
                @((MarkupString)Markdown.ToHtml(entry, _pipeline))
            </div>
        </div>
    }
}

