@page "/materials/new"
@page "/materials/{Id:guid}/edit"

<PageTitle>@(Id.HasValue ? L["material.edit"] : L["material.add"]) – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-database me-2"></i>@(Id.HasValue ? L["material.edit"] : L["material.add"])</h1>
</div>

@if (_loading) { <div class="text-center py-5"><div class="spinner-border"></div></div> }
else
{
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body">
                    @if (_error != null) { <div class="alert alert-danger">@_error</div> }

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.type"] *</label>
                            <input class="form-control" list="type-list" @bind="_form.Type" required />
                            <datalist id="type-list">
                                <option value="PLA"/><option value="PETG"/><option value="ABS"/><option value="ASA"/>
                                <option value="TPU"/><option value="Nylon"/><option value="PC"/><option value="HIPS"/>
                                <option value="PVA"/><option value="Wood"/><option value="Metal"/>
                            </datalist>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.brand"] *</label>
                            <input class="form-control" @bind="_form.Brand" required />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">@L["material.color.hex"] *</label>
                        <div class="input-group">
                            <input type="color" class="form-control form-control-color" value="@("#" + _form.ColorHex)" @oninput="OnColorPick" />
                            <input class="form-control font-monospace text-uppercase" maxlength="6" @bind="_form.ColorHex" placeholder="FFFFFF" />
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        @foreach (var (hex, name) in ColorPresets)
                        {
                            <button type="button" class="btn btn-sm p-0 border" style="width:1.8rem;height:1.8rem;background:#@hex;border-radius:4px"
                                    title="@name" @onclick="() => _form.ColorHex = hex"></button>
                        }
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.color.name"] @L["common.optional"]</label>
                            <input class="form-control" @bind="_form.ColorName" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.diameter"]</label>
                            <select class="form-select" @bind="_diameterStr">
                                <option value="1.75">1.75 mm</option>
                                <option value="2.85">2.85 mm</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.min.temp"] *</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.MinTempCelsius" />
                                <span class="input-group-text">°C</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.max.temp"] *</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.MaxTempCelsius" />
                                <span class="input-group-text">°C</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.bed.temp"] @L["common.optional"]</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.BedTempCelsius" />
                                <span class="input-group-text">°C</span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.weight"] @L["common.optional"]</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.WeightGrams" />
                                <span class="input-group-text">g</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.density"] @L["common.optional"]</label>
                            <input class="form-control" type="number" step="0.01" @bind="_form.DensityGCm3" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.dry.temp"] @L["common.optional"]</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.DryTempCelsius" />
                                <span class="input-group-text">°C</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">@L["material.dry.time"] @L["common.optional"]</label>
                            <div class="input-group">
                                <input class="form-control" type="number" @bind="_form.DryTimeHours" />
                                <span class="input-group-text">h</span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.price"] @L["common.optional"]</label>
                            <div class="input-group">
                                <input class="form-control" type="number" step="0.01" min="0" @bind="_form.PricePerKg" />
                                <span class="input-group-text">€/kg</span>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">@L["material.reorder"] @L["common.optional"]</label>
                            <input class="form-control" type="url" @bind="_form.ReorderUrl" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["material.notes"] @L["common.optional"]</label>
                        <textarea class="form-control" rows="2" @bind="_form.Notes"></textarea>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isPublic" @bind="_form.IsPublic" />
                        <label class="form-check-label" for="isPublic">@L["material.public"]</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            @L["common.save"]
                        </button>
                        <a href="/materials" class="btn btn-secondary">@L["common.cancel"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
