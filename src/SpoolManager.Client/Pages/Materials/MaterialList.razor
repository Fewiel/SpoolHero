@page "/materials"

<PageTitle>@L["material.title"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-database me-2"></i>@L["material.title"]</h1>
    <div class="d-flex gap-2">
        <a href="/materials/suggest" class="btn btn-outline-warning" title="@L["material.suggest.new"]">
            <i class="bi bi-lightbulb me-1"></i><span class="d-none d-md-inline">@L["material.suggest.new"]</span>
        </a>
        <a href="/materials/share" class="btn btn-outline-secondary">
            <i class="bi bi-share me-1"></i>@L["material.share"]
        </a>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/materials/new")'>
            <i class="bi bi-plus-lg me-1"></i>@L["material.add"]
        </button>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-12 col-md-4">
        <select class="form-select" value="@_typeFilter" @onchange="OnTypeChanged">
            <option value="">@L["material.filter.type.all"]</option>
            @foreach (var t in _types)
            {
                <option value="@t">@t</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-4">
        <input class="form-control" list="brand-list" placeholder="@L["material.filter.brand"]"
               value="@_brandFilter" @oninput="OnBrandChanged" />
        <datalist id="brand-list">
            @foreach (var b in _brands)
            {
                <option value="@b" />
            }
        </datalist>
    </div>
    <div class="col-12 col-md-4">
        <input class="form-control" list="color-list" placeholder="@L["material.filter.color"]"
               value="@_colorFilter" @oninput="OnColorChanged" />
        <datalist id="color-list">
            @foreach (var c in _colors)
            {
                <option value="@c" />
            }
        </datalist>
    </div>
    <div class="col-auto d-flex align-items-center">
        <button class="btn btn-sm @(_favoritesOnly ? "btn-warning" : "btn-outline-warning")" @onclick="OnFavoritesFilterChanged" title="@L["material.filter.favorites"]">
            <i class="bi bi-star-fill"></i>
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border"></div></div>
}
else if (_totalCount == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-database fs-1"></i>
        <p class="mt-2">@L["common.none"]</p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">@_totalCount @L["admin.materials.total"]</small>
        @if (TotalPages > 1)
        {
            <small class="text-muted">@(_page + 1) / @TotalPages</small>
        }
    </div>

    <div class="table-responsive-card">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>@L["material.type"]</th>
                    <th>@L["material.brand"]</th>
                    <th>@L["material.color.hex"]</th>
                    <th class="d-none d-md-table-cell">Temp</th>
                    <th class="d-none d-md-table-cell">Ø</th>
                    <th>@L["common.actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _items)
                {
                    <tr>
                        <td><strong>@m.Type</strong></td>
                        <td>@m.Brand</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:1.2em;height:1.2em;background:#@m.ColorHex;border-radius:50%;border:1px solid var(--bs-border-color);flex-shrink:0"></div>
                                <small class="font-monospace">#@m.ColorHex</small>
                                @if (m.ColorName != null) { <small class="text-muted">@m.ColorName</small> }
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell">@m.MinTempCelsius–@m.MaxTempCelsius °C</td>
                        <td class="d-none d-md-table-cell">@m.DiameterMm mm</td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm @(Favorites.IsFavorite(m.Id) ? "btn-warning" : "btn-outline-warning")" @onclick="() => ToggleFavorite(m.Id)">
                                    <i class="bi @(Favorites.IsFavorite(m.Id) ? "bi-star-fill" : "bi-star")"></i>
                                </button>
                                @if (m.ReorderUrl != null)
                                {
                                    <a href="@m.ReorderUrl" target="_blank" rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-success" title="@L["material.reorder"]"
                                       @onclick="() => _ = Tickets.TrackReorderClickAsync(m.Id)">
                                        <i class="bi bi-cart"></i>
                                    </a>
                                }
                                @if (m.OfdVariantId != null)
                                {
                                    <a href="/materials/@m.Id/suggest" class="btn btn-sm btn-outline-warning" title="@L["material.suggest"]">
                                        <i class="bi bi-lightbulb"></i>
                                    </a>
                                }
                                <a href="/materials/@m.Id/edit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(m)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (TotalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-center">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(_page == 0 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => SetPage(0)"><i class="bi bi-chevron-bar-left"></i></button>
                </li>
                <li class="page-item @(_page == 0 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => SetPage(_page - 1)"><i class="bi bi-chevron-left"></i></button>
                </li>
                @foreach (var p in VisiblePages)
                {
                    <li class="page-item @(p == _page ? "active" : "")">
                        <button class="page-link" @onclick="() => SetPage(p)">@(p + 1)</button>
                    </li>
                }
                <li class="page-item @(_page >= TotalPages - 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => SetPage(_page + 1)"><i class="bi bi-chevron-right"></i></button>
                </li>
                <li class="page-item @(_page >= TotalPages - 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => SetPage(TotalPages - 1)"><i class="bi bi-chevron-bar-right"></i></button>
                </li>
            </ul>
        </nav>
    }
}

@if (_deleteTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation>
            <h5>@L["material.delete"]</h5>
            <p>@L["material.delete.confirm"]</p>
            <p><strong>@_deleteTarget.Brand @_deleteTarget.Type</strong></p>
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">@L["common.cancel"]</button>
                <button class="btn btn-danger" @onclick="DeleteAsync">@L["common.delete"]</button>
            </div>
        </div>
    </div>
}
