@page "/materials/orca"
@inject MaterialService Materials
@inject LocalizationService L
@inject IJSRuntime JS
@inject ProjectService Project

<PageTitle>@L["material.export.orca"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-box-seam me-2"></i>@L["material.export.orca"]</h1>
    <a href="/materials" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>@L["common.cancel"]
    </a>
</div>

<p class="text-muted">@L["material.export.orca.hint"]</p>

<div class="card mb-4">
        <div class="card-body">
            <h6 class="card-title">@L["material.export.orca.select"]</h6>

            <div class="mb-3">
                <MaterialPicker Value="_pickerId" OnSelected="OnPicked" />
            </div>

            @if (_selectedMaterials.Count > 0)
            {
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var m in _selectedMaterials)
                    {
                        <span class="badge bg-body-secondary text-body border d-flex align-items-center gap-1 py-2 px-2">
                            <span style="width:.8em;height:.8em;background:#@m.ColorHex;border-radius:50%;border:1px solid var(--bs-border-color)"></span>
                            @m.Brand @m.Type
                            @if (m.ColorName != null) { <span>- @m.ColorName</span> }
                            @if (m.MinTempCelsius == 0 || m.MaxTempCelsius == 0)
                            {
                                <i class="bi bi-exclamation-triangle text-warning ms-1" title="@L["material.export.orca.warning.short"]"></i>
                            }
                            <button type="button" class="btn-close btn-close-sm ms-1" style="font-size:.6rem"
                                    @onclick="() => Remove(m.Id)"></button>
                        </span>
                    }
                </div>

                <button class="btn btn-sm btn-outline-danger mb-3" @onclick="() => _selectedMaterials.Clear()">
                    <i class="bi bi-x-lg me-1"></i>@L["common.clear"]
                </button>
            }

            @{ var warnings = _selectedMaterials.Where(m => m.MinTempCelsius == 0 || m.MaxTempCelsius == 0).ToList(); }
            @if (warnings.Count > 0)
            {
                <div class="alert alert-warning py-2">
                    <i class="bi bi-exclamation-triangle me-1"></i>@L["material.export.orca.warning"]
                    <ul class="mb-0 mt-1 small">
                        @foreach (var w in warnings)
                        {
                            <li>
                                @w.Brand @w.Type @(w.ColorName != null ? $"- {w.ColorName}" : "")
                                @if (w.OfdVariantId != null)
                                {
                                    <a href="/materials/@w.Id/suggest" class="ms-1">@L["material.suggest"]</a>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="ExportSelectedAsync"
                disabled="@(_exporting || _selectedMaterials.Count == 0)">
            @if (_exporting) { <span class="spinner-border spinner-border-sm me-2"></span> }
            <i class="bi bi-download me-1"></i>@L["material.export.orca.button"] (@_selectedMaterials.Count)
        </button>

        <button class="btn btn-outline-primary" @onclick="ExportAllAsync" disabled="@_exporting">
            @if (_exporting) { <span class="spinner-border spinner-border-sm me-2"></span> }
            <i class="bi bi-download me-1"></i>@L["material.export.orca.all"]
        </button>
    </div>

    @if (_orcaError != null)
    {
        <div class="alert alert-danger mt-3 py-2">@_orcaError</div>
    }

    @if (_orcaSuccess)
    {
        <div class="alert alert-success mt-3 py-2">
            <i class="bi bi-check-circle me-1"></i>@L["material.export.orca.done"]
        </div>
    }

@code {
    private bool _exporting;
    private bool _orcaSuccess;
    private string? _orcaError;
    private Guid? _pickerId;
    private List<FilamentMaterialDto> _selectedMaterials = [];

    private void OnPicked(FilamentMaterialDto? m)
    {
        if (m == null) return;
        if (_selectedMaterials.Any(x => x.Id == m.Id)) return;
        _selectedMaterials.Add(m);
        _pickerId = null;
    }

    private void Remove(Guid id) => _selectedMaterials.RemoveAll(m => m.Id == id);

    private async Task ExportSelectedAsync()
    {
        await DoExport(_selectedMaterials.Select(m => m.Id).ToList());
    }

    private async Task ExportAllAsync()
    {
        await DoExport(null);
    }

    private async Task DoExport(List<Guid>? ids)
    {
        _exporting = true;
        _orcaError = null;
        _orcaSuccess = false;
        try
        {
            var result = await Materials.ExportOrcaAsync(ids);
            if (result.HasValue)
            {
                await JS.InvokeVoidAsync("downloadHelper.saveAs", result.Value.Data, result.Value.Filename);
                _orcaSuccess = true;
            }
            else
            {
                _orcaError = "Export failed.";
            }
        }
        catch (Exception ex)
        {
            _orcaError = ex.Message;
        }
        _exporting = false;
    }
}
