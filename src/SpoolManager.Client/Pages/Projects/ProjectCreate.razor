@page "/projects/new"

<PageTitle>@L["project.create"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-diagram-3 me-2"></i>@L["project.create"]</h1>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">
                @if (_error != null) { <div class="alert alert-danger">@_error</div> }

                <div class="mb-3">
                    <label class="form-label">@L["project.name"] *</label>
                    <input class="form-control" @bind="_form.Name" maxlength="200"
                           placeholder="@L["project.name.placeholder"]" />
                    <small class="text-muted">@((_form.Name?.Length ?? 0)) / 200</small>
                </div>
                <div class="mb-4">
                    <label class="form-label">@L["project.description"] @L["common.optional"]</label>
                    <textarea class="form-control" rows="3" @bind="_form.Description"
                              placeholder="@L["project.description.placeholder"]"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        @L["project.create"]
                    </button>
                    @if (_hasProjects)
                    {
                        <a href="/projects" class="btn btn-secondary">@L["common.cancel"]</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

