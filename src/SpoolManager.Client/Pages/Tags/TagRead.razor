@page "/tags/read"

<PageTitle>@L["tag.read"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-broadcast me-2"></i>@L["tag.read"]</h1>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column gap-3">
                <h5 class="card-title">@L["tag.scan.title"]</h5>

                @if (_nfcSupported)
                {
                    @if (!_scanning)
                    {
                        <button class="btn btn-primary btn-lg w-100" @onclick="ScanNfcAsync">
                            <i class="bi bi-broadcast me-2"></i>@L["tag.nfc.scan"]
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-warning btn-lg w-100" @onclick="StopScanAsync">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            @L["tag.nfc.scanning"]
                        </button>
                    }
                }
                else
                {
                    <div class="alert alert-info py-2">
                        <i class="bi bi-info-circle me-2"></i>@L["tag.nfc.not.supported"]
                    </div>
                }

                @if (_error != null)
                {
                    <div class="alert alert-danger py-2">@_error</div>
                }
            </div>
        </div>
    </div>

    @if (_result != null)
    {
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    @if (_result.EntityType == "spool")
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-layers fs-3 text-primary"></i>
                            <h5 class="card-title mb-0">@L["tag.entity.spool"]</h5>
                        </div>
                        <p class="mb-1"><strong>@_result.EntityName</strong></p>
                        <small class="text-muted">@L["tag.entity.spool"] · ID: @_result.EntityId</small>
                        <div class="mt-3">
                            <a href="/spools/@_result.EntityId" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>@L["tag.view.details"]
                            </a>
                        </div>
                    }
                    else if (_result.EntityType == "printer")
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-printer fs-3 text-info"></i>
                            <h5 class="card-title mb-0">@L["tag.entity.printer"]</h5>
                        </div>
                        <p class="mb-1"><strong>@_result.EntityName</strong></p>
                        <small class="text-muted">@L["tag.entity.printer"] · ID: @_result.EntityId</small>
                    }
                    else if (_result.EntityType == "storage")
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-archive fs-3 text-success"></i>
                            <h5 class="card-title mb-0">@L["tag.entity.storage"]</h5>
                        </div>
                        <p class="mb-1"><strong>@_result.EntityName</strong></p>
                        <small class="text-muted">@L["tag.entity.storage"] · ID: @_result.EntityId</small>
                    }
                    else if (_result.EntityType == "dryer")
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-thermometer-half fs-3 text-warning"></i>
                            <h5 class="card-title mb-0">@L["tag.entity.dryer"]</h5>
                        </div>
                        <p class="mb-1"><strong>@_result.EntityName</strong></p>
                        <small class="text-muted">@L["tag.entity.dryer"] · ID: @_result.EntityId</small>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-question-circle fs-3 text-secondary"></i>
                            <h5 class="card-title mb-0">@L["tag.entity.unknown"]</h5>
                        </div>
                        <p class="text-muted mb-0">@L["tag.entity.unknown.hint"]</p>
                    }
                </div>
            </div>
        </div>
    }
</div>

