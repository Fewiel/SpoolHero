@page "/printers"

<PageTitle>@L["printer.title"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-printer me-2"></i>@L["printer.title"]</h1>
    <button class="btn btn-primary" @onclick="ShowAdd">
        <i class="bi bi-plus-lg me-1"></i>@L["printer.add"]
    </button>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border"></div></div>
}
else if (_printers.Count == 0 && _form == null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-printer fs-1"></i>
        <p class="mt-2">@L["common.none"]</p>
    </div>
}
else
{
    <div class="row g-3">
        @if (_form != null && _editId == null)
        {
            <div class="col-12 col-md-6 col-lg-4">
                @RenderForm()
            </div>
        }

        @foreach (var p in _printers)
        {
            <div class="col-12 col-md-6 col-lg-4">
                @if (_editId == p.Id && _form != null)
                {
                    @RenderForm()
                }
                else
                {
                    <div class="card h-100">
                        @if (p.ImageBase64 != null)
                        {
                            <img src="data:@p.ImageContentType;base64,@p.ImageBase64"
                                 class="card-img-top"
                                 style="height:120px; object-fit:cover;" />
                        }
                        <div class="card-body">
                            <h6 class="card-title mb-1">@p.Name</h6>
                            @if (p.Notes != null)
                            {
                                <p class="text-muted small mb-2">@p.Notes</p>
                            }
                            @if (p.RfidTagUid != null)
                            {
                                <p class="small mb-2">
                                    <i class="bi bi-broadcast me-1 text-success"></i>
                                    <span class="text-muted font-monospace">@p.RfidTagUid[..Math.Min(16, p.RfidTagUid.Length)]…</span>
                                </p>
                            }
                            @if (_imageError != null && _imageTargetId == p.Id)
                            {
                                <div class="alert alert-danger py-1 mb-2 small">@_imageError</div>
                            }
                            @if (_imageSuccess && _imageTargetId == p.Id)
                            {
                                <div class="alert alert-success py-1 mb-2 small">@L["common.image.upload.success"]</div>
                            }
                            <div class="d-flex gap-2 mt-2 flex-wrap">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowEdit(p)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => WriteTagAsync(p)" title="@L["tag.write"]">
                                    <i class="bi bi-broadcast"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => Tags.DownloadEntityBinAsync("printer", p.Id))" title="@L["tag.download.bin"]">
                                    <i class="bi bi-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => Tags.DownloadEntityJsonAsync("printer", p.Id))" title="@L["tag.download.json"]">
                                    <i class="bi bi-file-text"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => ShowEntityJsonAsync(p.Id))" title="@L["tag.show.json"]">
                                    <i class="bi bi-code"></i>
                                </button>
                                <label class="btn btn-sm btn-outline-secondary mb-0" title="@L["common.image.upload"]" style="cursor:pointer">
                                    <i class="bi bi-image"></i>
                                    <InputFile accept="image/*" style="display:none" OnChange="e => UploadImageAsync(p.Id, e)" />
                                </label>
                                @if (p.ImageBase64 != null)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" title="@L["common.image.delete"]" @onclick="() => DeleteImageAsync(p.Id)">
                                        <i class="bi bi-image-x"></i>
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteTarget = p">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            @if (_jsonTarget == p.Id && _jsonPayload != null)
                            {
                                <div class="position-relative mt-2">
                                    <pre class="small bg-body-secondary text-body border rounded p-2 pe-5 mb-0" style="font-size:0.7rem;word-break:break-all;white-space:pre-wrap;">@_jsonPayload</pre>
                                    <button class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-1" @onclick="CopyJsonAsync" title="@L["common.copy"]">
                                        <i class="bi @(_jsonCopied ? "bi-check-lg text-success" : "bi-clipboard")"></i>
                                    </button>
                                </div>
                            }
                            @if (_tagMessage != null && _tagPrinterId == p.Id)
                            {
                                <div class="alert @(_tagSuccess ? "alert-success" : "alert-danger") alert-sm py-1 mt-2 mb-0 small">@_tagMessage</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@{ RenderFragment RenderForm() => __builder =>
{
    <div class="card h-100 border-primary">
        <div class="card-body">
            @if (_error != null) { <div class="alert alert-danger py-2 mb-2">@_error</div> }
            <div class="mb-2">
                <label class="form-label">@L["printer.name"] *</label>
                <input class="form-control" @bind="_form!.Name" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["printer.notes"] @L["common.optional"]</label>
                <textarea class="form-control" rows="2" @bind="_form!.Notes"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm" @onclick="SaveAsync">@L["common.save"]</button>
                <button class="btn btn-secondary btn-sm" @onclick="Cancel">@L["common.cancel"]</button>
            </div>
        </div>
    </div>
}; }

@if (_deleteTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation>
            <h5>@L["printer.delete"]</h5>
            <p>@L["printer.delete.confirm"]</p>
            <p><strong>@_deleteTarget.Name</strong></p>
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">@L["common.cancel"]</button>
                <button class="btn btn-danger" @onclick="DeleteAsync">@L["common.delete"]</button>
            </div>
        </div>
    </div>
}

