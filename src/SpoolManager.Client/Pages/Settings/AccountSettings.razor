@page "/settings/account"
@inject AuthService Auth
@inject LocalizationService L
@inject NavigationManager Nav

<PageTitle>@L["settings.account.title"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-person-gear me-2"></i>@L["settings.account.title"]</h1>
</div>

@if (Auth.CurrentUser == null)
{
    <div class="text-center py-5"><div class="spinner-border text-secondary"></div></div>
}
else
{
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-info-circle me-2"></i>@L["settings.account.info.title"]
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">@L["auth.username"]</dt>
                <dd class="col-sm-9">@Auth.CurrentUser.Username</dd>
                <dt class="col-sm-3">@L["auth.email"]</dt>
                <dd class="col-sm-9">@Auth.CurrentUser.Email</dd>
                <dt class="col-sm-3">@L["settings.account.member.since"]</dt>
                <dd class="col-sm-9">@Auth.CurrentUser.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-signpost-split me-2"></i>@L["settings.account.onboarding.title"]
        </div>
        <div class="card-body">
            <p class="text-muted">@L["settings.account.onboarding.hint"]</p>

            @if (_onboardingMessage != null)
            {
                <div class="alert @(_onboardingSuccess ? "alert-success" : "alert-danger") py-2">
                    @_onboardingMessage
                </div>
            }

            <button class="btn btn-outline-primary" @onclick="ShowOnboardingAgainAsync" disabled="@_onboardingLoading">
                @if (_onboardingLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-arrow-counterclockwise me-1"></i>@L["settings.account.onboarding.show.again"]
            </button>
        </div>
    </div>

    <div class="card border-danger">
        <div class="card-header fw-semibold text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@L["settings.account.delete.title"]
        </div>
        <div class="card-body">
            <p class="text-muted">@L["settings.account.delete.warning"]</p>

            <button class="btn btn-outline-danger" @onclick="() => _showDeleteModal = true" disabled="@(Auth.CurrentUser.IsSuperAdmin)">
                <i class="bi bi-trash me-1"></i>@L["settings.account.delete.button"]
            </button>
            @if (Auth.CurrentUser.IsSuperAdmin)
            {
                <div class="form-text text-muted mt-1">@L["settings.account.delete.superadmin"]</div>
            }
        </div>
    </div>
}

@if (_showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-danger">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>@L["settings.account.delete.title"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>@L["settings.account.delete.warning"]</p>
                    <label class="form-label fw-semibold">@L["settings.account.delete.confirm"]</label>
                    <input type="password" class="form-control" @bind="_deletePassword" @bind:event="oninput"
                           placeholder="@L["auth.password"]" aria-label="@L["auth.password"]" />
                    @if (_deleteModalError != null)
                    {
                        <div class="text-danger small mt-1">@_deleteModalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteModal = false; _deletePassword = string.Empty; _deleteModalError = null; }">
                        @L["common.cancel"]
                    </button>
                    <button class="btn btn-danger" @onclick="DeleteAccountAsync" disabled="@(_deleting || string.IsNullOrWhiteSpace(_deletePassword))">
                        @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @L["settings.account.delete.button"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _showDeleteModal;
    private string _deletePassword = string.Empty;
    private string? _deleteModalError;
    private bool _deleting;
    private bool _onboardingLoading;
    private bool _onboardingSuccess;
    private string? _onboardingMessage;

    private async Task ShowOnboardingAgainAsync()
    {
        _onboardingLoading = true;
        _onboardingMessage = null;

        var ok = await Auth.SetDashboardOnboardingDismissedAsync(false);
        _onboardingLoading = false;
        _onboardingSuccess = ok;
        _onboardingMessage = ok
            ? L["settings.account.onboarding.success"]
            : L["settings.account.onboarding.error"];
    }

    private async Task DeleteAccountAsync()
    {
        if (string.IsNullOrWhiteSpace(_deletePassword)) return;
        _deleting = true;
        _deleteModalError = null;

        var resp = await Auth.DeleteAccountAsync(_deletePassword);
        _deleting = false;

        if (resp.IsSuccessStatusCode)
        {
            _showDeleteModal = false;
            await Auth.LogoutAsync();
            Nav.NavigateTo("/login");
        }
        else
        {
            _deleteModalError = L["settings.account.delete.error"];
        }
    }
}
