@page "/inventory"

<PageTitle>@L["inventory.title"] – @L["app.name"]</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-arrow-left-right me-2"></i>@L["inventory.title"]</h1>
</div>

@if (!_nfcSupported.HasValue)
{
    <div class="text-center py-5"><div class="spinner-border"></div></div>
}
else if (!_nfcSupported.Value)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>@L["tag.nfc.not.supported"]
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            @if (_state != ScanState.Done)
            {
                <div class="card mb-3">
                    <div class="card-body py-2 d-flex align-items-center justify-content-between gap-2 flex-wrap">
                        <span class="badge bg-primary-subtle text-primary-emphasis">
                            @GetProgressLabel()
                        </span>
                        <div class="btn-group btn-group-sm">
                            @if (_scannerRunning)
                            {
                                <button class="btn btn-outline-secondary" @onclick="PauseScannerAsync">
                                    <i class="bi bi-pause-fill me-1"></i>@L["inventory.reader.pause"]
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary" @onclick="ResumeScannerAsync">
                                    <i class="bi bi-play-fill me-1"></i>@L["inventory.reader.resume"]
                                </button>
                            }
                            <button class="btn btn-outline-secondary" @onclick="RestartAsync">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>@L["inventory.scan.reset"]
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (_hintMessage != null)
            {
                <div class="alert @(_hintIsWarning ? "alert-warning" : "alert-info") mb-3">
                    <i class="bi @(_hintIsWarning ? "bi-exclamation-triangle" : "bi-info-circle") me-2"></i>@_hintMessage
                </div>
            }

            @if (_state == ScanState.ScanningFirst)
            {
                <div class="card border-primary text-center">
                    <div class="card-body py-5">
                        <i class="bi bi-broadcast display-1 text-primary mb-3"></i>
                        <h4>@L["inventory.scan.first"]</h4>
                        <p class="text-muted">@L["tag.nfc.scanning"]</p>
                    </div>
                </div>
            }

            @if (_state == ScanState.ScanningSecond && _firstEntity != null)
            {
                <div class="card border-success mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <i class="@GetIcon(_firstEntity.EntityType) fs-2 text-success"></i>
                            <div>
                                <div class="small text-muted">@L["inventory.scanned.first"]</div>
                                <strong>@_firstEntity.EntityName</strong>
                                <span class="badge bg-secondary ms-2">@L[$"inventory.type.{_firstEntity.EntityType}"]</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-primary text-center">
                    <div class="card-body py-4">
                        <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
                        <h5>@L["inventory.scan.second"]</h5>
                        <p class="text-muted small">@L["inventory.hint.different"]</p>
                    </div>
                </div>
            }

            @if (_state == ScanState.Done)
            {
                @if (_result != null)
                {
                    <div class="card @(_result.Success ? "border-success" : "border-danger") text-center mb-3">
                        <div class="card-body py-5">
                            <i class="bi @(_result.Success ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") display-3 mb-3"></i>
                            <h4>@(_result.Success ? L["common.success"] : L["common.error"])</h4>
                            <p>@_result.Description</p>
                        </div>
                    </div>
                }
            }

            @if (_errorMessage != null)
            {
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@_errorMessage
                </div>
            }

            <div class="card mt-4">
                <div class="card-body small text-muted">
                    <strong>@L["inventory.help.title"]</strong>
                    <ul class="mb-0 mt-1">
                        <li>@L["inventory.help.spool.to.printer"]</li>
                        <li>@L["inventory.help.spool.to.storage"]</li>
                        <li>@L["inventory.help.printer.to.spool"]</li>
                        <li>@L["inventory.help.storage.to.spool"]</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
}

