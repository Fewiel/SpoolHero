{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=SpoolManager;User=spoolmanager;Password=YOUR_DB_PASSWORD;"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001",
        "Certificate": {
          "Path": "path/to/your.pfx",
          "Password": "YOUR_CERTIFICATE_PASSWORD"
        }
      }
    }
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS",
    "Issuer": "SpoolManager",
    "Audience": "SpoolManager",
    "ExpiresInHours": 24
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
